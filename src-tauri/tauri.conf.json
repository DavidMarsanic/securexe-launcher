{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Securexe Launcher",
  "version": "0.1.0",
  "identifier": "com.brightencode.securexe-launcher",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Securexe Launcher",
        "width": 420,
        "height": 220,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["securexe"]
      }
    }
  }
}
